{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/export/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/import/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/features/consultant-spotlight/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/features/burnout/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/features/psych-safety/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/remind",
      "schedule": "0 23 * * 0-4"
    },
    {
      "path": "/api/cron/remind",
      "schedule": "15 23 * * 0-4"
    },
    {
      "path": "/api/cron/remind",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/remind",
      "schedule": "15 8 * * 1-5"
    }
  ]
}
