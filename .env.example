# ===== Supabase設定 (Required) =====

# Supabase URL
SUPABASE_URL=

# Supabase Service Role Key (サーバーサイドのみ使用)
SUPABASE_SERVICE_ROLE_KEY=

# ===== 必須環境変数 (Required) =====

# Notion API トークン（必須）
# 取得方法: https://developers.notion.com/docs
NOTION_API_TOKEN=

# 参加者DB ID（必須）
# Notion内の参加者データベースのID
NOTION_PARTICIPANTS_DB_ID=

# マネージャーDB ID（必須）
# Notion内のマネージャーデータベースのID
NOTION_MANAGERS_DB_ID=

# コアログDB ID（必須）
# Notion内のコアログ（日報）データベースのID
NOTION_CORELOG_DB_ID=

# ミッションDB ID（必須）
# Notion内のミッションデータベースのID
NOTION_MISSION_DB_ID=

# Resend API キー（必須）
# Resend経由でメール送信するためのAPI キー
# 取得方法: https://resend.com/docs
RESEND_API_KEY=

# Cron Secret（必須）
# Vercel Cronからのリクエストを認証するためのシークレット
# Vercelダッシュボードで設定
CRON_SECRET=

# ===== オプション環境変数 (Optional) =====

# Anthropic API キー（オプション）
# Claude AIを使う機能で必要
# 取得方法: https://console.anthropic.com
ANTHROPIC_API_KEY=

# フィードバックDB ID（オプション）
# Notion内のフィードバックデータベースのID
NOTION_FEEDBACK_DB_ID=

# AI設定ページID（オプション）
# Notion内のAI設定ページのID
NOTION_AI_SETTINGS_PAGE_ID=

# 管理者トークン（オプション）
# カンマ区切りで複数の管理者トークンを指定可能
# 例: token1,token2,token3
ADMIN_TOKENS=

# デフォルトテナントID（オプション）
# マルチテナント対応時に環境変数で切り替え可能
DEFAULT_TENANT_ID=81f91c26-214e-4da2-9893-6ac6c8984062

# OTP認証の有効化（オプション）
# feature flagでも制御可能。trueの場合、メールでワンタイムパスワードを送信
OTP_ENABLED=false

# ===== アプリケーション設定 =====

# 本番環境のアプリケーションURL
# メール内のリンク等で使用
NEXT_PUBLIC_APP_URL=https://core-log.example.com

# リマインダーメール送信元（オプション）
# 例: "CORE Log <noreply@example.com>"
REMIND_FROM_EMAIL=CORE Log <noreply@resend.dev>

# Node環境（開発/本番）
NODE_ENV=production
